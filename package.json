{
  "name": "woodsheep",
  "version": "1.0.0",
  "description": "This template should help get you started developing with Vue 3 in Vite.",
  "main": "vitest.config.js",
  "scripts": {
    "dev": "vite",
    "build": "rimraf dist && vite build",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "predeploy": "npm run build",
    "build:vercel": "vite build --config vite.config.vercel.js",
    "vercel:prepare": "node pre-deploy-vercel.js",
    "deploy:vercel": "npm run build:vercel && npm run vercel:prepare && vercel --prod --cwd vercel-dist"
  },
  "keywords": [],
  "author": "Kevin Lau",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.14.0",
    "dotenv": "^17.4.1",
    "element-plus": "^2.13.2",
    "pinia": "^3.0.4",
    "rss-parser": "^3.13.0",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "gh-pages": "^6.3.0",
    "rimraf": "^6.1.2",
    "sass": "^1.97.3",
    "supabase": "^2.84.4",
    "vite": "^7.3.1"
  }
}
